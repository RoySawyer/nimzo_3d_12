msgstr "Здесь 0,04 (4 процента) — коэффициент корректировки прочности (SAF)."

#: main_12.cpp:376
msgid "ED is the effective rating difference."
msgstr "ED — эффективная разница рейтингов."

#: main_12.cpp:378
msgid "ED is has a positive value when calculating the ranking of the"
msgstr "ED имеет положительное значение при расчете рейтинга"

